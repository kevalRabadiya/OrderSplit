# Local MongoDB
# MONGODB_URI=mongodb://127.0.0.1:27017/tiffin

# MongoDB Atlas (replace USER, PASSWORD, cluster host; keep /tiffin database name)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/tiffin

PORT=5000

# Optional: comma-separated extra allowed CORS origins (full URLs, no trailing slash).
# Localhost and all https://*.onrender.com origins are allowed by default.
# CORS_ORIGINS=https://my-frontend.vercel.app,https://app.example.com
